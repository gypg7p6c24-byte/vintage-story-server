# Base image runtime
# 1.21.6 => 8.0-bookworm-slim
# Future 1.22 validation image => 10.0-bookworm-slim
DOTNET_RUNTIME_TAG=8.0-bookworm-slim

# Container user mapping
PUID=1000
PGID=1000

# Preferred: paste the official Linux server download URL copied from your
# Vintage Story account page. If omitted, the image falls back to the pinned
# version from .vintagestory-version. This is applied on first install only,
# unless VS_FORCE_REINSTALL=true.
VS_DOWNLOAD_URL=
VS_VERSION=

# Server settings
VS_SERVER_NAME=Vintage Story Docker Server
VS_SERVER_DESCRIPTION=
VS_WELCOME_MESSAGE=Welcome {0}, may you survive well and prosper
VS_SERVER_LANGUAGE=en
VS_PORT=42420
VS_MAX_CLIENTS=8
VS_ADVERTISE_SERVER=false
VS_VERIFY_PLAYER_AUTH=true
VS_PASS_TIME_WHEN_EMPTY=false
VS_ALLOW_PVP=true
VS_ALLOW_FIRE_SPREAD=true
VS_ALLOW_FALLING_BLOCKS=true
VS_WORLD_NAME=Vintage Story Docker World
VS_PASSWORD=
VS_BIND_IP=
VS_SAVE_FILE=

# Runtime behavior
# Manual updates only. Changing VS_DOWNLOAD_URL or VS_VERSION does nothing on
# an existing install unless VS_FORCE_REINSTALL=true.
VS_FORCE_REINSTALL=false
VS_BOOTSTRAP_TIMEOUT=60
VS_SERVER_ARGS=
